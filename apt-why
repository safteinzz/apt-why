#!/bin/bash
# apt-why — interactive package investigator
# Usage: apt-why                  fzf all installed packages
#        apt-why --upgradable     fzf upgradable packages only

R='\033[0;31m' Y='\033[0;33m' G='\033[0;32m'
C='\033[0;36m' W='\033[1;37m' M='\033[0;35m'
DIM='\033[2m' BOLD='\033[1m' RESET='\033[0m'

# ── Preflight ──────────────────────────────────────────────────────────────────
if ! command -v fzf &>/dev/null; then
    printf "${R}fzf is required.${RESET} Install with: sudo apt install fzf\n"
    exit 1
fi

MODE="all"
case "${1:-}" in
    --upgradable) MODE="upgradable" ;;
    --help|-h)
        printf "\n  ${BOLD}apt-why${RESET} — interactive package investigator\n\n"
        printf "  ${C}apt-why${RESET}               fzf over all installed packages\n"
        printf "  ${C}apt-why --upgradable${RESET}  fzf over upgradable packages only\n\n"
        printf "  Inside fzf: type to filter, enter to investigate, q/esc to go back\n\n"
        exit 0 ;;
esac

# ── Bulk data loading ──────────────────────────────────────────────────────────
printf "${DIM}  loading package data...${RESET}\r"

mapfile -t MANUAL_PKGS < <(apt-mark showmanual 2>/dev/null)

declare -A PKG_DESC PKG_ISIZE PKG_VERSION
while IFS=$'\t' read -r name ver isize desc; do
    [[ -z "$name" ]] && continue
    PKG_VERSION["$name"]="$ver"
    PKG_ISIZE["$name"]="${isize:-0}"
    PKG_DESC["$name"]="$desc"
done < <(
    dpkg-query -W -f='${Package}\t${Version}\t${Installed-Size}\t${Description}\n' 2>/dev/null \
        | awk -F'\t' '{
            desc = $4
            sub(/\n.*/, "", desc)
            printf "%s\t%s\t%s\t%s\n", $1, $2, $3, substr(desc, 1, 72)
        }'
)

declare -A PKG_CANDIDATE
while IFS= read -r line; do
    [[ "$line" =~ ^Listing ]] && continue
    pkg=$(echo "$line" | awk -F'/' '{print $1}')
    cand=$(echo "$line" | awk '{print $2}')
    [[ -n "$pkg" && -n "$cand" ]] && PKG_CANDIDATE["$pkg"]="$cand"
done < <(apt list --upgradable 2>/dev/null)

declare -A RDEP_MAP DEP_MAP
while IFS=$'\t' read -r pkg dep; do
    [[ -z "$dep" || -z "$pkg" ]] && continue
    RDEP_MAP["$dep"]+=" $pkg"
    DEP_MAP["$pkg"]+=" $dep"
done < <(
    dpkg-query -W -f='${Package}\t${Depends}\t${Recommends}\n' 2>/dev/null \
    | awk -F'\t' '{
        pkg = $1
        deps = $2 "," $3
        gsub(/ \([^)]*\)/, "", deps)
        gsub(/ \|[^,]*/, "", deps)
        n = split(deps, arr, ",")
        for (i = 1; i <= n; i++) {
            dep = arr[i]
            gsub(/^ +| +$/, "", dep)
            if (dep != "" && dep != pkg) printf "%s\t%s\n", pkg, dep
        }
    }'
)

mapfile -t ALL_INSTALLED  < <(dpkg-query -W -f='${Package}\n' 2>/dev/null | sort -u)
mapfile -t UPGRADABLE_PKGS < <(
    apt list --upgradable 2>/dev/null \
        | grep -v '^Listing' \
        | awk -F'/' '{print $1}' \
        | sort -u
)

printf "                          \r"

# ── Helpers ────────────────────────────────────────────────────────────────────
is_manual()     { [[ " ${MANUAL_PKGS[*]} " == *" $1 "* ]]; }
is_upgradable() { [[ " ${UPGRADABLE_PKGS[*]} " == *" $1 "* ]]; }
is_kernel_pkg() {
    [[ "$1" =~ ^linux-         ]] && return 0
    [[ "$1" =~ ^(intel|amd64)-microcode$ ]] && return 0
    [[ "$1" =~ ^firmware-      ]] && return 0
    [[ "$1" =~ ^initramfs      ]] && return 0
    return 1
}

format_size() {
    local kb=${1:-0}
    [[ "$kb" =~ ^[0-9]+$ ]] || kb=0
    if   [[ $kb -gt 102400 ]]; then printf "%4.0fMB" "$(echo "scale=0; $kb/1024" | bc)"
    elif [[ $kb -gt 10240  ]]; then printf "%4.0fMB" "$(echo "scale=0; $kb/1024" | bc)"
    elif [[ $kb -gt 0      ]]; then printf "%4dKB"   "$kb"
    else                              printf "  n/a"
    fi
}

get_install_date() {
    local pkg="$1" result=""
    result=$(grep -h " install ${pkg}:" /var/log/dpkg.log /var/log/dpkg.log.* 2>/dev/null \
        | grep -v "half-installed\|^status" \
        | awk 'NR==1 {print $1, $2}')
    if [[ -z "$result" ]]; then
        result=$(zcat /var/log/dpkg.log.*.gz 2>/dev/null \
            | grep " install ${pkg}:" \
            | grep -v "half-installed\|^status" \
            | awk 'NR==1 {print $1, $2}')
    fi
    echo "${result:-unknown}"
}

get_session_pkgs() {
    local pkg="$1" install_dt=""

    install_dt=$(
        {
            grep -h " install ${pkg}:" /var/log/dpkg.log /var/log/dpkg.log.* 2>/dev/null
            zcat /var/log/dpkg.log.*.gz 2>/dev/null | grep " install ${pkg}:"
        } | grep -v "half-installed\|^status" \
          | awk 'NR==1 {print $1, $2}'
    )
    [[ -z "$install_dt" ]] && return

    local install_epoch
    install_epoch=$(date -d "$install_dt" +%s 2>/dev/null) || return

    local all_log
    all_log=$(
        {
            grep -h " install " /var/log/dpkg.log /var/log/dpkg.log.* 2>/dev/null
            zcat /var/log/dpkg.log.*.gz 2>/dev/null | grep " install "
        } | grep -v "half-installed\|^status"
    )

    pkgs_in_window() {
        local lo=$(( install_epoch - $1 ))
        local hi=$(( install_epoch + $1 ))
        echo "$all_log" | awk -v lo="$lo" -v hi="$hi" -v pkg="$pkg" '
            {
                split($1, d, "-"); split($2, t, ":")
                ts = mktime(d[1]" "d[2]" "d[3]" "t[1]" "t[2]" "t[3])
                if (ts < lo || ts > hi) next
                name = $4; sub(/:.*$/, "", name); gsub(/ /, "", name)
                if (name != "" && name != pkg) print name
            }
        ' | sort -u
    }

    local result="" count=0
    for w in 259200 86400 43200 21600; do   # 3d 1d 12h 6h
        result=$(pkgs_in_window "$w")
        count=$(echo "$result" | grep -c .)
        [[ $count -le 20 ]] && break
        result=""
    done

    [[ -z "$result" ]] && result=$(pkgs_in_window 21600)

    echo "$result"
}

rdeps_of() {
    local rdeps="${RDEP_MAP[$1]:-}"
    local -A _seen
    for dep in $rdeps; do
        [[ -v _seen["$dep"] ]] && continue
        _seen["$dep"]=1
        echo "$dep"
    done
}

deps_of() {
    local deps="${DEP_MAP[$1]:-}"
    local -A _seen
    for dep in $deps; do
        [[ -v _seen["$dep"] ]] && continue
        _seen["$dep"]=1
        echo "$dep"
    done
}

# ── Dossier ────────────────────────────────────────────────────────────────────
show_dossier() {
    local pkg="$1"
    local mark ver_line install_date
    local -a rdeps_arr deps_arr session_arr

    clear

    is_manual "$pkg" \
        && mark="${G}[M] manually installed${RESET}" \
        || mark="${Y}[A] auto-installed${RESET}"

    local ver="${PKG_VERSION[$pkg]:-unknown}"
    local upgr_badge=""
    if is_upgradable "$pkg" && [[ -n "${PKG_CANDIDATE[$pkg]:-}" ]]; then
        ver_line="${ver}  ${C}->  ${PKG_CANDIDATE[$pkg]}${RESET}"
        upgr_badge="  ${C}↑ upgrade available${RESET}"
    else
        ver_line="$ver"
    fi

    install_date=$(get_install_date "$pkg")
    mapfile -t rdeps_arr   < <(rdeps_of "$pkg")
    mapfile -t deps_arr    < <(deps_of  "$pkg")
    mapfile -t session_arr < <(get_session_pkgs "$pkg")

    printf "\n${BOLD}${W}  %s${RESET}%b\n" "$pkg" "$upgr_badge"
    printf "  ${DIM}%s${RESET}\n\n" "${PKG_DESC[$pkg]:-no description available}"
    printf "  ${DIM}status   :${RESET}  %b\n"  "$mark"
    printf "  ${DIM}version  :${RESET}  %b\n"  "$ver_line"
    printf "  ${DIM}size     :${RESET}  %s\n"  "$(format_size "${PKG_ISIZE[$pkg]:-0}")"
    printf "  ${DIM}installed:${RESET}  %s\n"  "$install_date"

    if [[ ${#rdeps_arr[@]} -gt 0 ]]; then
        printf "\n  ${BOLD}needed by${RESET} ${DIM}(%d):${RESET}\n" "${#rdeps_arr[@]}"
        local i=0
        for r in "${rdeps_arr[@]}"; do
            [[ $i -ge 5 ]] \
                && printf "    ${DIM}... and %d more (available in navigator below)${RESET}\n" \
                    $(( ${#rdeps_arr[@]} - i )) \
                && break
            local r_m; is_manual "$r" && r_m="${G}[M]${RESET}" || r_m="${Y}[A]${RESET}"
            printf "    %b  ${C}%-30s${RESET}  ${DIM}%s${RESET}\n" \
                "$r_m" "$r" "${PKG_DESC[$r]:0:45}"
            (( i++ ))
        done
    else
        if is_kernel_pkg "$pkg"; then
            printf "\n  ${Y}nothing explicitly depends on this${RESET}\n"
            printf "  ${R}kernel/firmware package — do not remove${RESET}\n"
        else
            printf "\n  ${Y}nothing depends on this${RESET}\n"
            printf "  ${DIM}safe to remove: sudo apt remove %s${RESET}\n" "$pkg"
        fi
    fi

    local session_count=${#session_arr[@]}
    if [[ $session_count -gt 0 ]]; then
        local -a sess_manual=() sess_auto=()
        for s in "${session_arr[@]}"; do
            s="${s// /}"
            [[ -z "$s" ]] && continue
            is_manual "$s" && sess_manual+=("$s") || sess_auto+=("$s")
        done
        local -a sess_sorted=("${sess_manual[@]}" "${sess_auto[@]}")
        local sorted_count=${#sess_sorted[@]}

        printf "\n  ${BOLD}installed same session${RESET} ${DIM}(%d packages):${RESET}\n" "$sorted_count"
        local shown=0
        for s in "${sess_sorted[@]}"; do
            if [[ $shown -ge 20 ]]; then
                printf "    ${DIM}+ %d more${RESET}\n" $(( sorted_count - shown ))
                break
            fi
            local s_m; is_manual "$s" && s_m="${G}[M]${RESET}" || s_m="${Y}[A]${RESET}"
            printf "    %b  %-30s  ${DIM}%s${RESET}\n" "$s_m" "$s" "${PKG_DESC[$s]:0:45}"
            (( shown++ ))
        done
    fi

    printf "\n"

    # ── fzf nav pool: needed-by + depends-on
    local -A _nav_seen
    local -a nav_lines=()

    for r in "${rdeps_arr[@]}"; do
        [[ -v _nav_seen["$r"] ]] && continue
        _nav_seen["$r"]=1
        local r_m; is_manual "$r" \
            && r_m=$'\033[0;32m[M]\033[0m' || r_m=$'\033[0;33m[A]\033[0m'
        nav_lines+=("$(printf "%s %-34s\t%s" \
            "$r_m" "$r" "${PKG_DESC[$r]:0:60}")")
    done
    for d in "${deps_arr[@]}"; do
        [[ -v _nav_seen["$d"] ]] && continue
        _nav_seen["$d"]=1
        local d_m; is_manual "$d" \
            && d_m=$'\033[0;32m[M]\033[0m' || d_m=$'\033[0;33m[A]\033[0m'
        nav_lines+=("$(printf "%s %-34s\t%s" \
            "$d_m" "$d" "${PKG_DESC[$d]:0:60}")")
    done

    if [[ ${#nav_lines[@]} -gt 0 ]]; then
        local selected
        local nav_header
        nav_header="$(printf "  Dependencies of: %s\n  [M]=manual  [A]=auto  |  enter=open  esc/ctrl+c=back" "$pkg")"
        selected=$(printf '%s\n' "${nav_lines[@]}" \
            | fzf --ansi --prompt="  apt-why > " \
                --delimiter=$'\t' --nth=1 \
                --height=40% \
                --border=rounded \
                --color="prompt:cyan,pointer:#b48ead,hl:yellow,header:cyan,bg+:#3b3052,fg+:#e0d0f0" \
                --bind="esc:abort,ctrl-c:abort" \
                --header="$nav_header" \
                --header-first \
                2>/dev/null \
            | awk '{print $2}') || true
        [[ -n "$selected" ]] && show_dossier "$selected"
    else
        printf "  ${DIM}no related packages to navigate.  press any key to go back${RESET}\n"
        read -rsn1 < /dev/tty
    fi
}

# ── Package list line ──────────────────────────────────────────────────────────
build_list_line() {
    local pkg="$1"
    local mark_raw mark upgr
    is_manual "$pkg" && mark_raw="[M]" || mark_raw="[A]"
    is_manual "$pkg" \
        && mark=$'\033[0;32m'"$mark_raw"$'\033[0m' \
        || mark=$'\033[0;33m'"$mark_raw"$'\033[0m'
    is_upgradable "$pkg" \
        && upgr=$'\033[0;36m↑\033[0m' \
        || upgr=" "
    printf "%s %-35s\t%s  %-8s %s\n" \
        "$mark" "$pkg" "$upgr" \
        "$(format_size "${PKG_ISIZE[$pkg]:-0}")" \
        "${PKG_DESC[$pkg]:0:55}"
}

# ── Main loop ──────────────────────────────────────────────────────────────────
if [[ "$MODE" == "upgradable" ]]; then
    PKG_POOL=("${UPGRADABLE_PKGS[@]}")
    FZF_HDR="$(printf "  upgradable packages %s\n  [M]=manual  [A]=auto  ↑=upgrade pending   |  enter=open  esc/ctrl+c=back")"
else
    PKG_POOL=("${ALL_INSTALLED[@]}")
    FZF_HDR="$(printf "  all installed packages %s\n  [M]=manual  [A]=auto  ↑=upgrade available   |  enter=open  esc/ctrl+c=back")"
fi

while true; do
    selected=$(
        for pkg in "${PKG_POOL[@]}"; do
            build_list_line "$pkg"
        done \
        | fzf --ansi --prompt="  apt-why > " \
            --delimiter=$'\t' --nth=1 \
            --height=70% \
            --border=rounded \
            --color="prompt:cyan,pointer:#b48ead,hl:yellow,header:cyan,bg+:#3b3052,fg+:#e0d0f0" \
            --bind="esc:abort,ctrl-c:abort" \
            --header="$FZF_HDR" \
            --header-first \
            2>/dev/null \
        | awk '{print $2}'
    ) || true

    [[ -z "$selected" ]] && break
    show_dossier "$selected"
    clear
done

printf "\n${DIM}  bye${RESET}\n\n"
